# Configuration de l'application
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/diabetes

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (mobile sign-in)
# Web client ID from Google Cloud Console (required to verify mobile ID tokens on backend)
GOOGLE_WEB_CLIENT_ID=
# Optional: comma-separated list of accepted client IDs (Android/iOS/Web)
GOOGLE_OAUTH_CLIENT_IDS=

# CORS
CORS_ORIGIN=http://localhost:3000

# AI Services
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llava:13b
OLLAMA_TEXT_MODEL=llama3.1:8b

# RevenueCat (Premium patient subscriptions + Doctor Boost)
REVENUECAT_SECRET_KEY=
REVENUECAT_WEBHOOK_AUTH_SECRET=
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
REVENUECAT_PREMIUM_PRODUCT_ID=diabcare_premium_monthly
REVENUECAT_PREMIUM_AMOUNT=6.5
REVENUECAT_PREMIUM_CURRENCY=eur
REVENUECAT_MEDECIN_BOOST_ENTITLEMENT_ID=doctor_boost
REVENUECAT_BOOST_7D_PRODUCT_ID=diabcare_boost_7d
REVENUECAT_BOOST_15D_PRODUCT_ID=diabcare_boost_15d
REVENUECAT_BOOST_30D_PRODUCT_ID=diabcare_boost_30d
REVENUECAT_MEDECIN_BOOST_CURRENCY=eur